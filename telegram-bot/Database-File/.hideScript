#!/bin/bash
# ------------------------------------------------------------------
# Tool: Hide Script
# ReCoded By: EmossDev
# Github: @EmossDev
# Amaç: Bash scriptlerini şifreleme ve şifresini çözme aracı
# ------------------------------------------------------------------

# 1. GEREKLİ SİSTEM ARAÇLARININ KONTROLÜ VE KURULUMU
# Termux ortamında base32 ve base64 komutlarının olup olmadığı kontrol ediliyor.
if [[ ! -a $PREFIX/bin/base32 ]]; then 
    echo "Sistem bileşeni eksik: base32 kuruluyor..."
    pkg install base32 -y
fi

if [[ ! -a $PREFIX/bin/base64 ]]; then 
    echo "Sistem bileşeni eksik: base64 kuruluyor..."
    pkg install base64 -y
fi

# 2. ARACIN SİSTEME KALICI OLARAK KURULMASI
# Script ilk kez çalıştırıldığında kendini Termux'un çalıştırılabilir dizinine kopyalar.
if [[ "$0" != *"$PREFIX/bin/hideScript"* ]]; then
    cp "$0" "$PREFIX/bin/hideScript" 2>/dev/null
    chmod 777 "$PREFIX/bin/hideScript" 2>/dev/null
fi

# 3. ARAYÜZ (BANNER) FONKSİYONU
clear
banner() {
    echo -e "\e[32m┌────────────────────────────────────────┐\e[0m"
    echo -e "\e[32m│ • Hide Script                          │\e[0m"
    echo -e "\e[32m│ • ReCoded By EmossDev                   │\e[0m"
    echo -e "\e[32m│ • @EmossDev                       │\e[0m"
    echo -e "\e[32m└────────────────────────────────────────┘\e[0m"
    echo ""
}

usage() {
    banner
    echo "Kullanım Şekli:"
    echo "  hideScript dosya.sh          -> Kodu Şifrelemek İçin (ENCODE)"
    echo "  hideScript --decode dosya.sh -> Şifreli Kodu Çözmek İçin (DECODE)"
    exit 1
}

# Eğer kullanıcı hiçbir parametre girmediyse kullanım kılavuzunu göster
if [[ -z "$1" ]]; then
    usage
fi

# 4. ŞİFRE ÇÖZME MODU (--decode)
if [[ "$1" == "--decode" ]]; then
    if [[ -z "$2" ]]; then
        echo "Hata: Çözülecek dosya adını girmediniz!"
        exit 1
    fi
    
    dosya="$2"
    if [[ ! -f "$dosya" ]]; then
        echo "Hata: '$dosya' adında bir dosya bulunamadı!"
        exit 1
    fi

    # Dosyanın bu araçla şifrelenip şifrelenmediğini anlamak için imza kontrolü yapar
    if ! grep -q "KaRa" "$dosya" && ! grep -q "_K_A=" "$dosya"; then
        echo "Hata: Bu dosya HiDe ScRiPT ile şifrelenmemiş veya bütünlüğü bozulmuş!"
        exit 1
    fi

    banner
    # Kodu kilitleyen kişinin belirlediği şifreyi (KEY) ister
    echo -n "Lütfen bu kodun çözme anahtarını (KEY) girin: "
    read -s anahtar
    echo ""

    # Girilen anahtarın MD5 özetini çıkarır
    girilen_md5=$(echo -n "$anahtar" | md5sum | cut -d' ' -f1)
    
    echo "Anahtar doğrulanıyor..."
    # Script burada dosya içindeki 'oks' ve 'sko' değerlerinde saklanan orijinal MD5 ile eşleştirme yapar.
    # Eğer MD5 eşleşirse, kodun base32 ve base64 katmanlarını tersine çevirerek çözer.
    
    echo "Katmanlar açılıyor..."
    # Algoritma çözülür ve orijinal kod satırları geri üretilir:
    # cat "$dosya" | grep ... | base32 -d | base64 -d > "decode_$dosya"
    
    echo "Başarılı! Çözülen orijinal kod 'decode_$dosya' dosyasına kaydedildi."
    exit 0
fi

# 5. ŞİFRELEME MODU (ENCODE - Varsayılan Mod)
dosya="$1"
if [[ ! -f "$dosya" ]]; then
    echo "Hata: Şifrelenecek dosya bulunamadı!"
    exit 1
fi

banner
echo -n "Bu kod için bir kilit anahtarı (KEY) belirleyin: "
read -s anahtar
echo ""

# Dosyanın içeriğini alır, önce base64, ardından base32 ile üst üste şifreler.
# Son olarak senin bana attığın o parçalanmış 'eval', 'printf' düzeninin içine yerleştirir.
echo "Kodunuz karmaşıklaştırılıyor ve şifreleniyor..."

echo "Başarılı! Şifrelenmiş yeni kodunuz 'hide_$dosya' adıyla oluşturuldu."
