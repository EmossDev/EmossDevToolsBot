# EmossDev Panel — Ortam değişkenleri örneği
# Bu dosyayı kopyalayıp .env olarak kaydet: cp .env.example .env

# Admin panelin çalışacağı port (varsayılan: 3000)
PORT=3000

# TWA (Android APK) için — opsiyonel
# TWA_PACKAGE_NAME=com.emossdevtoolsbot.twa
# TWA_FINGERPRINT=AA:BB:CC:...

# SESSION_SECRET — panel oturumları için (rastgele bir şey yaz)
# SESSION_SECRET=cok_gizli_bir_sifre_123
